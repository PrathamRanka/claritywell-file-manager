# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/docvault"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-me-for-production"

# AWS S3 (Optional - only if implementing file uploads)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-key"
AWS_SECRET_ACCESS_KEY="your-secret"
AWS_S3_BUCKET="your-bucket"

# Application
NODE_ENV="development"
