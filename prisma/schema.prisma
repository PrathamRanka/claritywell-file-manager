datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

enum Role {
  ADMIN
  USER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DocumentType {
  WYSIWYG
  IMAGE
  PDF
}

enum Visibility {
  PRIVATE
  DEPARTMENT
  SHARED
}

enum AuditAction {
  CREATE
  EDIT
  DELETE
  MOVE
  COPY
  SHARE
  LOGIN
  LOGOUT
  UPLOAD
  COMMENT
  RESTORE
}

enum RequirementStatus {
  OPEN
  IN_PROGRESS
  REVIEW
  COMPLETED
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  passwordHash          String
  role                  Role
  name                  String
  avatarUrl             String?
  lastLoginAt           DateTime?
  createdAt             DateTime           @default(now())
  departmentMemberships DepartmentMember[]
  documentsCreated      Document[]         @relation("DocumentOwner")
  requirementsCreated   Requirement[]      @relation("RequirementCreator")
  foldersCreated        Folder[]           @relation("FolderCreator")
  comments              Comment[]          @relation("CommentAuthor")
  documentAcls          DocumentACL[]
  grantedAcls           DocumentACL[]      @relation("AclGrantor")
  addedFolderItems      FolderItem[]       @relation("FolderItemAdder")
  auditLogs             AuditLog[]         @relation("AuditUser")
}

model Department {
  id           String             @id @default(cuid())
  name         String             @unique
  createdAt    DateTime           @default(now())
  members      DepartmentMember[]
  requirements Requirement[]
}

model DepartmentMember {
  userId       String
  departmentId String
  joinedAt     DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}

model Requirement {
  id           String            @id @default(cuid())
  clientName   String
  dueDate      DateTime
  priority     Priority
  status       RequirementStatus @default(OPEN)
  departmentId String
  createdById  String
  createdAt    DateTime          @default(now())

  department   Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("RequirementCreator", fields: [createdById], references: [id])
  documents    Document[]

  @@index([departmentId])
  @@index([createdById])
  @@index([dueDate])
  @@index([status])
  @@index([departmentId, status])
}

model Document {
  id             String        @id @default(cuid())
  title          String
  type           DocumentType
  visibility     Visibility
  ownerId        String
  requirementId  String?
  storagePath    String?
  mimeType       String?
  contentHtml    String?
  contentExcerpt String?       @db.VarChar(250)
  thumbnailPath  String?
  deletedAt      DateTime?     // Soft delete indicator
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner          User          @relation("DocumentOwner", fields: [ownerId], references: [id])
  requirement    Requirement?  @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  folderItems    FolderItem[]
  comments       Comment[]
  acl            DocumentACL[]

  @@index([ownerId])
  @@index([requirementId])
  @@index([visibility])
  @@index([deletedAt])
  @@index([ownerId, deletedAt])
  @@index([visibility, deletedAt])
}

model DocumentACL {
  id           String   @id @default(cuid())
  documentId   String
  userId       String
  grantedById  String?
  canEdit      Boolean  @default(false)
  canComment   Boolean  @default(false)
  canView      Boolean  @default(true)
  createdAt    DateTime @default(now())

  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy    User?    @relation("AclGrantor", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@index([documentId, userId, canView])
}

model Folder {
  id          String       @id @default(cuid())
  name        String
  parentId    String?
  createdById String
  visibility  Visibility   @default(PRIVATE)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())

  parent      Folder?      @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders  Folder[]     @relation("FolderToFolder")
  createdBy   User         @relation("FolderCreator", fields: [createdById], references: [id])
  items       FolderItem[]

  @@index([createdById])
  @@index([parentId])
  @@index([deletedAt])
  @@index([createdById, deletedAt])
  @@index([visibility])
}

model FolderItem {
  id         String   @id @default(cuid())
  folderId   String
  documentId String
  addedById  String?
  createdAt  DateTime @default(now())

  folder     Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  addedBy    User?    @relation("FolderItemAdder", fields: [addedById], references: [id], onDelete: SetNull)

  @@unique([folderId, documentId])
  @@index([folderId])
  @@index([documentId])
  @@index([folderId, createdAt])
}

model Comment {
  id              String    @id @default(cuid())
  documentId      String
  authorId        String
  content         String
  parentCommentId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author          User      @relation("CommentAuthor", fields: [authorId], references: [id])
  parentComment   Comment?  @relation("CommentToComment", fields: [parentCommentId], references: [id], onDelete: Cascade)
  childComments   Comment[] @relation("CommentToComment")

  @@index([documentId])
  @@index([authorId])
  @@index([parentCommentId])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  userId     String
  documentId String?
  folderId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  user       User        @relation("AuditUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([documentId])
  @@index([folderId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
}
